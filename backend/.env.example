NODE_ENV=development
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

QUEUE_NAME=media-transcode
QUEUE_CONCURRENCY=2
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_MS=2000

MAX_URL_LENGTH=2048
REQUEST_BODY_LIMIT=32kb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_DOWNLOAD_MAX=20

TEMP_DIR=./tmp
FILE_TTL_MINUTES=20
CLEANUP_INTERVAL_MS=60000

ALLOWED_SOURCE_DOMAINS=localhost,127.0.0.1,cdn.example.com,s3.amazonaws.com,storage.googleapis.com
ENABLE_DOMAIN_ALLOWLIST=false
BOT_SHARED_SECRET=

SOCKET_CORS_ORIGIN=http://localhost:3000
